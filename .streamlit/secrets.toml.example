# ─────────────────────────────────────────────────────────────────────────────
# ARCHIVO DE EJEMPLO — secrets.toml
# ─────────────────────────────────────────────────────────────────────────────
# En Streamlit Cloud: ve a tu app → Settings → Secrets
# Copia el contenido de abajo (sin el .example) y rellena tus datos reales.
#
# NO subas este archivo a GitHub con datos reales.
# ─────────────────────────────────────────────────────────────────────────────

[email]
# Servidor SMTP (Gmail por defecto)
smtp_server    = "smtp.gmail.com"
smtp_port      = 587

# Correo desde el que se envían los mensajes de recuperación
sender_email   = "tu_correo@gmail.com"

# Contraseña de APLICACIÓN de Gmail (no es tu contraseña normal)
# Cómo crearla:
#   1. myaccount.google.com → Seguridad → Verificación en dos pasos (actívala)
#   2. Seguridad → Contraseñas de aplicaciones → Generar (elige "Correo" / "Otro")
#   3. Copia las 16 letras que te da (con o sin espacios, ambas funcionan)
sender_password = "xxxx xxxx xxxx xxxx"

# URL pública de tu app en Streamlit Cloud (sin barra final)
# Ejemplo: https://debajo-del-horreo.streamlit.app
app_url        = "https://TU-APP.streamlit.app"
